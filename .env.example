# [Database]
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Note: sslmode=require and channel_binding=require are mandatory for Neon

# [Auth]
# Secret key for signing JWT tokens
SECRET_KEY=your_super_secret_jwt_key
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Image Storage (Cloudinary) ─────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Local fallback used if Cloudinary not configured
UPLOAD_DIR=uploads

# [AI/ML]
# Google Gemini API key for image analysis
GOOGLE_API_KEY=your_google_ai_studio_api_key
# Minimum confidence score for AI to accept classification (0.0 to 1.0)
AI_CONFIDENCE_THRESHOLD=0.7

# [Geofencing]
# Maximum distance in meters a collector can be from a bin to collect it
GEOFENCE_RADIUS_METERS=500.0

# [Business Logic]
# Percentage at which a bin is considered ready for collection (0 to 100)
BIN_COLLECTION_THRESHOLD_PERCENT=75
# Minutes to wait before allowing another report for the same bin to prevent spam
SPAM_WINDOW_MINUTES=30
# Default capacity for a collection truck in kg
DEFAULT_TRUCK_CAPACITY_KG=500.0
